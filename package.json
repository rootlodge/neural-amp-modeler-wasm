{
  "name": "@opencollabhut/nam-wasm",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Neural Amp Modeler WASM with multi-instance support for Web Audio integration",
  "author": "CollabHut",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./nam.wasm": "./dist/nam.wasm",
    "./nam.js": "./dist/nam.js"
  },
  "scripts": {
    "build:wasm": "node scripts/build-wasm.js",
    "build:ts": "tsc && node scripts/copy-dts.js",
    "build": "npm run build:wasm && npm run build:ts",
    "clean": "node scripts/clean-dist.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rootlodge/neural-amp-modeler-wasm.git"
  },
  "keywords": [
    "neural-amp-modeler",
    "nam",
    "guitar-amp",
    "amp-simulation",
    "webassembly",
    "wasm",
    "web-audio",
    "audio-worklet",
    "dsp"
  ],
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
